{
  "root": "dist",
  "clean_urls": true,
  "error_page": "index.html",

  "routes": {
    "/assets/*": "/assets/:splat",
    "/*": "index.html"
  },

  "headers": {
    "/assets/*": {
      "Cache-Control": "public, max-age=31536000, immutable"
    },
    "/index.html": {
      "Cache-Control": "no-cache, no-store, must-revalidate"
    },
    "/manifest.webmanifest": {
      "Cache-Control": "no-cache"
    },
    "/sw.js": {
      "Cache-Control": "no-cache, no-store, must-revalidate"
    },
    "/service-worker.js": {
      "Cache-Control": "no-cache, no-store, must-revalidate"
    }
  },

  "https_only": true,

  "proxies": {
    "/api": {
      "origin": "https://assesslyplatform-t49h.onrender.com"
    }
  }
}
