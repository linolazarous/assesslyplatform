{
  "name": "assessly-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Assessly - Modern AI-Powered Assessment Platform",

  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },

  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "serve": "vite preview --host",
    "preview": "vite preview --port 4173 --host",
    "start": "vite preview --host --port $PORT",
    "analyze": "npm run build -- --mode analyze",
    "render-build": "npm ci --legacy-peer-deps && npm run build",
    "clean-install": "rm -rf node_modules package-lock.json && npm install --legacy-peer-deps"
  },

  "dependencies": {
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "@mui/icons-material": "^5.16.7",
    "@mui/material": "^5.16.7",
    "@tanstack/react-query": "^5.62.3",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "axios": "^1.7.2",
    "chart.js": "^4.4.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.13",
    "framer-motion": "^12.23.24",
    "jspdf": "^3.0.3",
    "jspdf-autotable": "^5.0.2",
    "jwt-decode": "^4.0.0",
    "notistack": "^3.0.1",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.1",
    "react-confetti": "^6.1.0",
    "react-helmet-async": "^2.0.4",
    "recharts": "^2.15.0",
    "vite": "^5.2.8",
    "vite-plugin-pwa": "^0.17.4",
    "xlsx": "^0.18.5"
  },

  "devDependencies": {
    "@babel/preset-react": "^7.24.7",
    "@emotion/babel-plugin": "^11.11.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/chart.js": "^2.9.41",
    "dotenv": "^16.3.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "rollup-plugin-visualizer": "^5.12.0",
    "typescript": "^5.4.5"
  },

  "browserslist": {
    "production": [
      ">0.3%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 2 chrome versions",
      "last 2 firefox versions",
      "last 2 edge versions"
    ]
  },

  "keywords": [
    "assessly",
    "ai-assessment",
    "react",
    "vite",
    "education",
    "frontend",
    "cors",
    "axios"
  ],

  "license": "MIT"
}
