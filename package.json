{
  "name": "assessly-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "Assessly - Modern AI-Powered Assessment Platform",

  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },

  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "serve": "vite preview --host",
    "preview": "vite preview --port 4173 --host",

    "start": "vite preview --host --port $PORT",
    "render-build": "npm ci && npm run build",
    "clean-install": "rm -rf node_modules package-lock.json && npm install",
    
    "render-dev": "vite",
    "render-start": "vite preview --port $PORT --host"
  },

  "dependencies": {
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "@hookform/resolvers": "^3.9.1",
    "@mui/icons-material": "^5.16.7",
    "@mui/material": "^5.16.7",
    "@tanstack/react-query": "^5.62.3",
    "axios": "^1.7.2",
    "chart.js": "^4.4.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.13",
    "framer-motion": "^12.23.24",
    "jspdf": "^3.0.3",
    "jspdf-autotable": "^5.0.2",
    "jwt-decode": "^4.0.0",
    "notistack": "^3.0.1",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-confetti": "^6.1.0",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.4",
    "react-hook-form": "^7.52.3",
    "react-router-dom": "^6.26.1",
