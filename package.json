    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.0",
    "vite-plugin-pwa": "^1.2.0"
  },

  "browserslist": {
    "production": [
      ">0.3%",
      "not dead",
      "not op_mini all"
