#############################################################
# 🌍 ENVIRONMENT & SERVER CONFIGURATION
#############################################################
NODE_ENV=production
PORT=10000
APP_NAME=Assessly Platform API
LOG_LEVEL=info
TRUST_PROXY=true
ENABLE_STATUS_MONITOR=true

#############################################################
# 💾 DATABASE (MongoDB Atlas)
#############################################################
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/assessly?retryWrites=true&w=majority
MONGODB_CONNECTION_TIMEOUT=30000
AUTO_SEED=true

#############################################################
# 🔑 JWT AUTHENTICATION & TOKENS
#############################################################
JWT_SECRET=super_secure_random_jwt_secret_key_please_change_me_32chars_min
JWT_REFRESH_SECRET=super_secure_refresh_token_secret_different_from_above
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
TOKEN_ISSUER=assessly-platform
TOKEN_AUDIENCE=https://assessly-gedp.onrender.com

#############################################################
# 💳 STRIPE PAYMENT CONFIGURATION
#############################################################
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Subscription Price IDs
STRIPE_BASIC_PRICE_ID=price_basic_plan
STRIPE_PROFESSIONAL_PRICE_ID=price_professional_plan
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_plan

#############################################################
# 🧠 AI INTEGRATION (OpenAI / GPT / Assessly AI)
#############################################################
OPENAI_API_KEY=sk-your_openai_api_key_here
AI_ASSISTANT_NAME=Assessly Mentor
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=4096

#############################################################
# 📧 EMAIL (SMTP / Nodemailer / Notifications)
#############################################################
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=linolaku560@gmail.com
SMTP_PASS=your_app_password
SMTP_SECURE=true

EMAIL_SENDER="Assessly Notifications <no-reply@assessly.com>"
EMAIL_SUPPORT=admin@assessly.com
EMAIL_CONTACT_RECEIVER=admin@assessly.com
EMAIL_BCC=audits@assessly.com

#############################################################
# 🌐 CORS, URLS, & SECURITY HEADERS
#############################################################
FRONTEND_URL=https://assessly-gedp.onrender.com
BACKEND_URL=https://assesslyplatform-t49h.onrender.com
CLIENT_URL=https://assessly-gedp.onrender.com

ALLOWED_ORIGINS=https://assessly-gedp.onrender.com,https://assesslyplatform-t49h.onrender.com,http://localhost:5173,http://localhost:3000
SECURE_COOKIES=true
COOKIE_SAME_SITE=None
ENABLE_CORS_LOGGING=false

#############################################################
# 👥 ADMIN / ACCESS CONTROL
#############################################################
ADMIN_EMAIL=admin@assessly.com
ALLOW_ADMIN_SIGNUP=false
ENABLE_USER_ACTIVITY_LOGS=true
ENABLE_RATE_LIMIT=true
ENABLE_SECURITY_HEADERS=true

#############################################################
# 📊 MONITORING, LOGGING & DEBUGGING
#############################################################
ENABLE_MORGAN_LOGS=true
ENABLE_REQUEST_DEBUG=false
ENABLE_API_DOCS=true
ENABLE_HEALTH_ROUTE=true
ENABLE_STATUS_MONITOR=true
SHOW_STACK_TRACE=false

#############################################################
# 🚀 FEATURE FLAGS & EXPERIMENTAL MODULES
#############################################################
ENABLE_AI_COURSE_GENERATION=true
ENABLE_GAMIFICATION=true
ENABLE_BADGES=true
ENABLE_BLOCKCHAIN_CERTIFICATES=false
ENABLE_NOTIFICATIONS=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_SUBSCRIPTION_BILLING=true
ENABLE_MULTILANGUAGE_SUPPORT=true
ENABLE_AUTO_BACKUPS=true
ENABLE_ACTIVITY_ANALYTICS=true
ENABLE_USER_SESSIONS_TRACKING=true

#############################################################
# ⚙️ ADVANCED SECURITY
#############################################################
RATE_LIMIT_WINDOW_MINUTES=1
RATE_LIMIT_MAX_REQUESTS=20
ENABLE_XSS_PROTECTION=true
ENABLE_MONGO_SANITIZE=true
ENABLE_HSTS=true
ENABLE_HELMET=true
ENABLE_CONTENT_SECURITY_POLICY=true

#############################################################
# 🔔 NOTIFICATIONS & EVENTS
#############################################################
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_AI_ASSISTANT_NOTIFICATIONS=true
ENABLE_PAYMENT_ALERTS=true
ENABLE_DAILY_SYSTEM_REPORTS=false

#############################################################
# 🔁 BACKUP & CRON JOBS
#############################################################
ENABLE_CRON_JOBS=true
BACKUP_CRON_SCHEDULE=0 3 * * *   # Every day at 3 AM
BACKUP_RETENTION_DAYS=7

#############################################################
# 🧩 MISC SETTINGS
#############################################################
SUPPORT_EMAIL=support@assessly.com
ORGANIZATION_NAME=Assessly Technologies
REGION=us-east-1
TIMEZONE=Africa/Juba
LANGUAGE=en
#############################################################
